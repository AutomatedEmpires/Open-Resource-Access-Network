##############################################
# ORAN Environment Variables
##############################################

# Local development:
# - Copy this file to `.env.local` and fill in values.
# - Never commit real secrets.
#
# Azure (recommended / "lockbox"):
# - Store secrets in Azure Key Vault.
# - Reference them from App Service application settings using Key Vault references.
#
# See:
# - docs/platform/DEPLOYMENT_AZURE.md
# - docs/platform/PLATFORM_AZURE.md

# Database
# - Local Docker Compose example (sslmode=disable is typical locally)
# - Azure Postgres should use sslmode=require
DATABASE_URL=postgres://oran:oran_local_password@localhost:5432/oran_db?sslmode=disable

# Microsoft Entra ID (Azure AD) — authentication provider
# If AZURE_AD_CLIENT_ID is not set, auth middleware becomes a no-op.
# Create an app registration in Azure Portal → Microsoft Entra ID → App registrations.
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# NextAuth.js
# NEXTAUTH_SECRET — generate with: openssl rand -base64 32
# NEXTAUTH_URL — set to your production URL; auto-detected in local dev.
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=

# Azure Communication Services — Email (optional)
# Connection string from Azure Portal → Communication Services → Keys
AZURE_COMMUNICATION_CONNECTION_STRING=
# Sender address configured in ACS Email → Provisioned domains
AZURE_COMMUNICATION_SENDER_ADDRESS=DoNotReply@<your-guid>.azurecomm.net

# Azure Cache for Redis (optional)
# Format: rediss://:password@hostname:6380  (TLS)
REDIS_URL=

# Internal API Key — shared secret for Azure Functions → App internal calls
# Generate with: openssl rand -base64 32
INTERNAL_API_KEY=

# Azure Maps — interactive service map
# Create via Azure Portal → Azure Maps → Subscription key (primary or secondary)
# If unset, the map page falls back to an OpenStreetMap tile layer automatically.
AZURE_MAPS_KEY=

##############################################
# Azure Key Vault "lockbox" notes
##############################################

# Key Vault secret names cannot include underscores, so we recommend hyphenated names.
# Example secret name mapping:
# - AZURE_AD_CLIENT_ID -> azure-ad-client-id
# - AZURE_AD_CLIENT_SECRET -> azure-ad-client-secret
# - AZURE_AD_TENANT_ID -> azure-ad-tenant-id
# - NEXTAUTH_SECRET -> nextauth-secret
# - NEXT_PUBLIC_SENTRY_DSN -> next-public-sentry-dsn
# - AZURE_COMMUNICATION_CONNECTION_STRING -> azure-communication-connection-string
# - REDIS_URL -> redis-url
# - INTERNAL_API_KEY -> internal-api-key
# - AZURE_MAPS_KEY -> azure-maps-key

# Set secrets in Key Vault (example):
#   az keyvault secret set --vault-name <kv-name> --name azure-ad-client-secret --value "..."
#   az keyvault secret set --vault-name <kv-name> --name nextauth-secret --value "..."

# Reference secrets from App Service settings (example pattern):
# 1) Get SecretUri:
#   az keyvault secret show --vault-name <kv-name> --name azure-ad-client-secret --query id -o tsv
# 2) Set App Service setting to a Key Vault reference:
#   az webapp config appsettings set --resource-group <rg> --name <webapp> \
#     --settings "AZURE_AD_CLIENT_SECRET=@Microsoft.KeyVault(SecretUri=<secretUri>)"

# The bootstrap script already wires DATABASE_URL via Key Vault reference:
# - scripts/azure/bootstrap.sh
