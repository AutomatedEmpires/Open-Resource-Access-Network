        "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('kvName'), 'azure-maps-key')]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('kvName'), 'azure-maps-sas-token')]",
