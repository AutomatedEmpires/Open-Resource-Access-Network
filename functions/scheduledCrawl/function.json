{
  "bindings": [
    {
      "name": "timer",
      "type": "timerTrigger",
      "direction": "in",
      "schedule": "0 0 6 * * *"
    },
    {
      "name": "$return",
      "type": "queue",
      "direction": "out",
      "queueName": "ingestion-fetch",
      "connection": "AzureWebJobsStorage"
    }
  ],
  "scriptFile": "../dist/functions/scheduledCrawl/index.js",
  "entryPoint": "scheduledCrawl"
}
