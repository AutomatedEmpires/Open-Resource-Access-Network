          "linuxFxVersion": "NODE|20-lts",
          "alwaysOn": "[not(equals(parameters('appServiceSku'), 'B1'))]",
          "ftpsState": "Disabled",
          "minTlsVersion": "1.2",
          "appSettings": "[concat(createArray(createObject('name', 'NODE_ENV', 'value', 'production'), createObject('name', 'NEXT_TELEMETRY_DISABLED', 'value', '1'), createObject('name', 'DATABASE_URL', 'value', format('@Microsoft.KeyVault(SecretUri={0})', reference(resourceId('Microsoft.KeyVault/vaults/secrets', variables('kvName'), 'database-url'), '2023-07-01').secretUri)), createObject('name', 'NEXTAUTH_SECRET', 'value', format('@Microsoft.KeyVault(SecretUri={0})', reference(resourceId('Microsoft.KeyVault/vaults/secrets', variables('kvName'), 'nextauth-secret'), '2023-07-01').secretUri)), createObject('name', 'NEXTAUTH_URL', 'value', if(not(empty(parameters('customHostname'))), format('https://{0}', parameters('customHostname')), format('https://{0}.azurewebsites.net', variables('webAppName')))), createObject('name', 'INTERNAL_API_KEY', 'value', format('@Microsoft.KeyVault(SecretUri={0})', reference(resourceId('Microsoft.KeyVault/vaults/secrets', variables('kvName'), 'internal-api-key'), '2023-07-01').secretUri)), createObject('name', 'AZURE_AD_CLIENT_ID', 'value', parameters('entraClientId')), createObject('name', 'AZURE_AD_TENANT_ID', 'value', parameters('entraTenantId')), createObject('name', 'NEXT_PUBLIC_SENTRY_DSN', 'value', parameters('sentryDsn')), createObject('name', 'APPLICATIONINSIGHTS_CONNECTION_STRING', 'value', reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString), createObject('name', 'AZURE_MAPS_KEY', 'value', format('@Microsoft.KeyVault(SecretUri={0})', reference(resourceId('Microsoft.KeyVault/vaults/secrets', variables('kvName'), 'azure-maps-key'), '2023-07-01').secretUri)), createObject('name', 'AZURE_MAPS_SAS_TOKEN', 'value', format('@Microsoft.KeyVault(SecretUri={0})', reference(resourceId('Microsoft.KeyVault/vaults/secrets', variables('kvName'), 'azure-maps-sas-token'), '2023-07-01').secretUri))), if(not(empty(parameters('entraClientSecret'))), createArray(createObject('name', 'AZURE_AD_CLIENT_SECRET', 'value', format('@Microsoft.KeyVault(SecretUri={0})', tryGet(if(not(empty(parameters('entraClientSecret'))), reference(resourceId('Microsoft.KeyVault/vaults/secrets', variables('kvName'), 'azure-ad-client-secret'), '2023-07-01', 'full'), null()), 'properties', 'secretUri')))), createArray()))]"
        }
      },
