# Example environment variables for ORAN.
#
# Do not put real secrets in this file.
# Copy to .env.local and fill in values for your environment.

# Database (local example; see db/README.md)
DATABASE_URL=postgresql://oran:oran_local_password@localhost:5432/oran_db?sslmode=disable

# Clerk (optional)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/chat
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/chat

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=
#+#+#+#+#+#+#+#+#+#+#+#+#+#+#+#+###############
# ORAN Environment Variables
##############################################

# Local development:
# - Copy this file to `.env.local` and fill in values.
# - Never commit real secrets.
#
# Azure (recommended / â€ślockboxâ€ť):
# - Store secrets in Azure Key Vault.
# - Reference them from App Service application settings using Key Vault references.
#
# See:
# - docs/DEPLOYMENT_AZURE.md
# - docs/PLATFORM_AZURE.md

# Database
# - Local Docker Compose example (sslmode=disable is typical locally)
# - Azure Postgres should use sslmode=require
DATABASE_URL=postgres://oran:oran_local_password@localhost:5432/oran_db?sslmode=disable

# Clerk (optional in local dev; middleware becomes a no-op if not set)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/chat
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/chat

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=

##############################################
# Azure Key Vault â€ślockboxâ€ť notes
##############################################

# Key Vault secret names cannot include underscores, so we recommend hyphenated names.
# Example secret name mapping:
# - NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY -> next-public-clerk-publishable-key
# - CLERK_SECRET_KEY -> clerk-secret-key
# - NEXT_PUBLIC_SENTRY_DSN -> next-public-sentry-dsn

# Set secrets in Key Vault (example):
#   az keyvault secret set --vault-name <kv-name> --name next-public-clerk-publishable-key --value "..."
#   az keyvault secret set --vault-name <kv-name> --name clerk-secret-key --value "..."
#   az keyvault secret set --vault-name <kv-name> --name next-public-sentry-dsn --value "..."

# Reference secrets from App Service settings (example pattern):
# 1) Get SecretUri:
#   az keyvault secret show --vault-name <kv-name> --name clerk-secret-key --query id -o tsv
# 2) Set App Service setting to a Key Vault reference:
#   az webapp config appsettings set --resource-group <rg> --name <webapp> \
#     --settings "CLERK_SECRET_KEY=@Microsoft.KeyVault(SecretUri=<secretUri>)"

# The bootstrap script already wires DATABASE_URL via Key Vault reference:
# - scripts/azure/bootstrap.sh
