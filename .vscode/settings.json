{
  "files.eol": "\n",
  "editor.formatOnSave": false,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": true
  },

  "eslint.useFlatConfig": true,

  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],

  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,

  "search.exclude": {
    ".next": true,
    "out": true,
    "build": true,
    "coverage": true,
    "dist": true
  },

  "files.exclude": {
    ".next": true,
    "dist": true
  },

  "files.watcherExclude": {
    "**/.next/**": true,
    "**/node_modules/**": true,
    "**/coverage/**": true,
    "**/build/**": true,
    "**/out/**": true,
    "**/dist/**": true
  },

  "prettier.requireConfig": true,

  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\\"'`]([^\\"'`]*).*?[\\"'`]"]
  ],

  // SQL migration files use PostgreSQL dialect, not T-SQL.
  // Disable MSSQL validation to avoid false-positive syntax errors on
  // valid PostgreSQL constructs (IF NOT EXISTS, JSONB, UUID, TIMESTAMPTZ, etc.).
  "mssql.pgsql.isEnabled": false
}
